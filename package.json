{
  "name": "gubblunch-bot",
  "version": "1.0.0",
  "description": "Slack bot with Gemini AI for per-channel topic management",
  "type": "module",
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "tsc",
    "build:lambda": "bun build ./src/lambda.ts --outfile=dist/lambda.js --target=node --format=cjs --external @aws-sdk/*",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1009.0",
    "@aws-sdk/lib-dynamodb": "^3.1009.0",
    "@google/genai": "^1.45.0",
    "@slack/bolt": "^4.6.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}